{
  "name": "hunter-x-coder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "IT Academy live demo — React & TypeScript. Defeat the Any-Type Demon with a crowd-powered Spirit Bomb.",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c magenta,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.server.json && vite build",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.server.json",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "playwright": "^1.61.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "ws": "^8.18.0"
  }
}
